<main class="hero">
  <div class="overlay"></div>
  <header class="center">
    <img class="logoLarge" src="/img/MQ_logo_gold.png" alt="Moroni's Quest logo" />
    <p class="tagline"><%= slogan %></p>
    <p class="event-date">July 7&ndash;10, 2026</p>
    <section class="countdown" aria-live="polite">
      <div class="time"><span id="d">0</span><small>Days</small></div>
      <div class="time"><span id="h">0</span><small>Hours</small></div>
